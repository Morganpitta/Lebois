{
  "type": "origins:multiple",
  "increment": {
    "type": "origins:action_over_time",
    "interval": 20,
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "lebois:stryder/oc_charge",
      "change": 1
    },
    "condition": {
      "type": "origins:power_active",
      "power": "lebois:stryder/oc_toggle",
      "inverted": true
    }
  },
  "decrement": {
    "type": "origins:action_over_time",
    "interval": 20,
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "lebois:stryder/oc_charge",
      "change": -1
    },
    "condition": {
      "type": "origins:power_active",
      "power": "lebois:stryder/oc_toggle"
    }
  },
  "hidden": true
}
